# Banco de dados
DATABASE_URL="postgresql://zux:zux@localhost:5432/zux_portal?schema=public"

# NextAuth
AUTH_SECRET="troque-isso-por-um-secret-forte-em-producao"
AUTH_URL="http://localhost:3000"

# Configurações de ponto / CLT
# Jornada padrão diária em minutos (8h = 480)
PONTO_JORNADA_DIARIA_MIN=480
# Tolerância para considerar atraso/extra (em minutos)
PONTO_TOLERANCIA_MIN=10
# Adicional de hora extra padrão (50%)
PONTO_ADICIONAL_HE=0.5
# Adicional para HE em domingo/feriado (100%)
PONTO_ADICIONAL_HE_DSR=1.0
