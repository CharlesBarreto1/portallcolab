# Config TEMPORÁRIA usada só para emitir o primeiro certificado SSL.
# Substitua por zux.conf depois que o Certbot gerar os arquivos.

server {
    listen 80;
    listen [::]:80;
    server_name __DOMAIN__;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 200 'Bootstrap em andamento. Aguardando emissão do certificado SSL.';
        add_header Content-Type text/plain;
    }
}
