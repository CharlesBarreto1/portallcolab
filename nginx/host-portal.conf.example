# Server block para o nginx INSTALADO NO HOST (não no Docker).
# Coloque em /etc/nginx/sites-available/portal.zux.net.br e ative com:
#   sudo ln -s /etc/nginx/sites-available/portal.zux.net.br /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Depois rode:
#   sudo certbot --nginx -d portal.zux.net.br --redirect
# Certbot vai adicionar SSL + redirect HTTP->HTTPS automaticamente.

server {
    listen 80;
    listen [::]:80;
    server_name portal.zux.net.br;

    client_max_body_size 25M;

    # Cache de assets estáticos do Next
    location /_next/static/ {
        proxy_pass http://127.0.0.1:3000;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_read_timeout 60s;
    }
}
