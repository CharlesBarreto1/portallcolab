# Copie para .env na VPS e preencha
# Gere AUTH_SECRET com:  openssl rand -base64 32
# NUNCA commite o .env real

# Postgres
POSTGRES_USER=zux
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
POSTGRES_DB=zux_portal

# Next/Auth.js
AUTH_SECRET=TROQUE_POR_OUTPUT_DO_OPENSSL_RAND
AUTH_URL=https://SEU_DOMINIO

# Ponto / CLT
PONTO_JORNADA_DIARIA_MIN=480
PONTO_TOLERANCIA_MIN=10
PONTO_ADICIONAL_HE=0.5
PONTO_ADICIONAL_HE_DSR=1.0

# Setar 1 SOMENTE NO PRIMEIRO BOOT para criar admin/colaborador de exemplo
SEED_ON_BOOT=0
